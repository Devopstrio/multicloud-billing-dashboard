# API Settings
API_V1_STR=/api/v1
PROJECT_NAME="Multi-Cloud Billing Dashboard"

# Security
SECRET_KEY=multicloudbillingdashboardsecret123
ACCESS_TOKEN_EXPIRE_MINUTES=11520

# Provider Credentials (Simulation)
AWS_BILLING_ROLE_ARN=arn:aws:iam::123456789012:role/FinOpsAccess
AZURE_TENANT_ID=azure-tenant-id-123
GCP_BILLING_PROJECT=finops-billing-project

# Database
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=billing_dashboard_db

# Redis / Queue
REDIS_HOST=localhost
REDIS_PORT=6379

# FinOps Settings
CURRENCY=USD
TAX_RATE=0.0
DEFAULT_RETENTION_DAYS=730

# Monitoring
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
